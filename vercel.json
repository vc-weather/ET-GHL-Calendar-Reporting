{
  "crons": [
    {
      "path": "/api/sync-ghl-calendar-calls",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/sync-ghl-calendar-calls-daily",
      "schedule": "15 7 * * *"
    }
  ],
  "functions": {
    "api/sync-ghl-calendar-calls.mjs": {
      "maxDuration": 60
    },
    "api/sync-ghl-calendar-calls-daily.mjs": {
      "maxDuration": 60
    }
  }
}
