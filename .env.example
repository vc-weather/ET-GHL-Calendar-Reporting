GHL_PRIVATE_INTEGRATION_TOKEN=
GHL_LOCATION_ID=

# Optional scoping. If omitted, the sync lists all location calendars and pulls each calendar.
# GHL_CALENDAR_IDS=calendar_id_1,calendar_id_2
# GHL_GROUP_ID=
# GHL_USER_ID=
# Optional. Only needed to enrich owner IDs into user names/emails.
# GHL_COMPANY_ID=

# Use YYYY-MM-DD or ISO timestamps. CLI defaults to the last 30 days through the next 90 days.
# Vercel hourly defaults to yesterday through tomorrow; Vercel daily defaults to last 7 days plus tomorrow.
# SYNC_START_DATE=2026-01-01
# SYNC_END_DATE=2026-12-31

# Contact custom fields can be read by exact custom-field id/key/name match.
# Include comma-separated fallbacks if your account names differ.
GHL_LEAD_SCORE_FIELDS=lead_score,Lead Score,score
GHL_AD_ID_FIELDS=Meta Ad ID,ad_id,Ad ID,adId,facebook_ad_id,Facebook Ad ID

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_TABLE=ghl_calendar_calls

# Recommended on Vercel. If set, manual calls must include either
# Authorization: Bearer <CRON_SECRET> or ?secret=<CRON_SECRET>.
CRON_SECRET=

# Set to true to print rows without writing to Supabase.
DRY_RUN=false

# Dry runs print a PII-light summary by default. Set to full only for debugging.
DRY_RUN_OUTPUT=summary

# Tuning for larger imports.
GHL_CONTACT_DELAY_MS=25
SYNC_PROGRESS_EVERY=50
SUPABASE_BATCH_SIZE=500
